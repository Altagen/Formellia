{
  "name": "formellia",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:api": "tsx tests/api/main.ts --base-url http://localhost:3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:seed": "dotenv -e .env.test -- npx tsx scripts/seed-test-db.ts",
    "test:db:up": "docker compose --profile test up -d db-test",
    "test:db:down": "docker compose --profile test stop db-test",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@dnd-kit/core": "^6.3.1",

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/formellia

# Lucia session secret — min 32 chars, generate with: openssl rand -base64 32
AUTH_SECRET=change-me-32-chars-minimum-here!!

# ── Email notifications (required only if email notifications are used) ────────

# AES-256-GCM key for encrypting stored email API keys — 64 hex chars
# Generate with: openssl rand -hex 32
# If not set, saving email notification API keys will fail gracefully.
ENCRYPTION_KEY=

# ── Security (optional — all have safe defaults) ──────────────────────────────

# Enforce password complexity policy (true/false). Overrides DB setting.
# ENFORCE_PASSWORD_POLICY=true

# Session duration in days (1–365). Overrides DB setting. Default: 30
# SESSION_DURATION_DAYS=30

# Max account creations per hour (0=disabled, 1–128). Overrides DB setting. Default: 5
# USER_CREATION_RATE_LIMIT=5

# ── Network / deployment ──────────────────────────────────────────────────────

# Restrict admin access to a specific hostname (e.g. admin.example.com)
# If set, requests with a different Host header are rejected with 403.
# ADMIN_HOST=admin.example.com

# Trusted proxy IP for X-Forwarded-For resolution (e.g. 10.0.0.1)
# TRUSTED_PROXY=

# Public-facing URL of the app (used for reset-password links, etc.)
# NEXT_PUBLIC_APP_URL=https://example.com

# ── Config source (optional) ──────────────────────────────────────────────────

# Config source: "db" (default) or "file"
# CONFIG_SOURCE=db

# Path to config.yaml — only used when CONFIG_SOURCE=file
# CONFIG_YAML_PATH=./config.yaml

# ── Bootstrap (optional — first-run only) ─────────────────────────────────────

# Seed an initial admin account on first start (only if no users exist)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Force password update on next restart (one-shot, then ignored)
# ADMIN_UPDATE_PASSWORD_ON_RESTART=false
